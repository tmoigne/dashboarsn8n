generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String           @id @default(cuid())
  email      String           @unique
  password   String
  name       String
  role       String           @default("user")
  createdAt  DateTime         @default(now())
  templates  EmailTemplate[]
  taskAccess UserTaskAccess[]
}

model UserTaskAccess {
  id        String   @id @default(cuid())
  userId    String
  taskId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, taskId])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  blocks    String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// Global app config — key/value (n8n instances, Claude key, etc.)
model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// n8n instances stored in DB
model N8nInstance {
  id        String   @id @default(cuid())
  name      String
  baseUrl   String
  apiKey    String
  active    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
