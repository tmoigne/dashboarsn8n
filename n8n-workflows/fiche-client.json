    {
      "parameters": {
        "jsCode": "// Accepte body JSON direct ou imbriqué\nconst body = $input.first().json.body ?? $input.first().json;\n\n// Champs attendus\nconst champs = [\n  'Civilité', 'Nom', 'Prénom', 'Raison sociale', 'Groupement',\n  'Forme juridique', 'Activité principale', 'Famille',\n  'Email de contact', 'Numéro de téléphone', 'Numéro de portable',\n  'Adresse', 'Adresse complémentaire', 'Ville', 'code postal',\n  \"Horaires d'ouverture\", 'Analyse société', 'Origine contact',\n  'Conditions de livraisons'\n];\n\n// Extrait uniquement les champs non vides\nconst data = {};\nfor (const c of champs) {\n  if (body[c] !== undefined && body[c] !== null && body[c] !== '') {\n    data[c] = body[c];\n  }\n}\n\nif (!data.Nom && !data['Email de contact'] && !data['Numéro de portable']) {\n  throw new Error('Au moins Nom, Email ou Téléphone requis');\n}\n\n// Construit la formule de recherche\nconst parts = [];\nif (data['Email de contact']) parts.push(`{Email de contact}=\"${data['Email de contact']}\"`);\nif (data['Numéro de portable']) parts.push(`{Numéro de portable}=\"${data['Numéro de portable']}\"`);\nif (data['Numéro de téléphone']) parts.push(`{Numéro de téléphone}=\"${data['Numéro de téléphone']}\"`);\nif (data.Nom && data.Prénom) parts.push(`AND({Nom}=\"${data.Nom}\",{Prénom}=\"${data.Prénom}\")`);\n\ndata._searchFormula = parts.length > 0 ? `OR(${parts.join(',')})` : 'FALSE()';\n\nreturn [{ json: data }];"
      },
