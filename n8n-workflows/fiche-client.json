        "jsonBody": "={\n  \"model\": \"claude-haiku-4-5-20251001\",\n  \"max_tokens\": 1024,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Extrais les informations client depuis ce texte et réponds UNIQUEMENT en JSON valide avec exactement ces champs (valeur null si absent) :\\n{\\n  \\\"Civilité\\\": null,\\n  \\\"Nom\\\": null,\\n  \\\"Prénom\\\": null,\\n  \\\"Raison sociale\\\": null,\\n  \\\"Groupement\\\": null,\\n  \\\"Forme juridique\\\": null,\\n  \\\"Activité principale\\\": null,\\n  \\\"Email de contact\\\": null,\\n  \\\"Numéro de téléphone\\\": null,\\n  \\\"Numéro de portable\\\": null,\\n  \\\"Adresse\\\": null,\\n  \\\"Adresse complémentaire\\\": null,\\n  \\\"Ville\\\": null,\\n  \\\"code postal\\\": null,\\n  \\\"Horaires d'ouverture\\\": null,\\n  \\\"Analyse société\\\": null,\\n  \\\"Origine contact\\\": null,\\n  \\\"Conditions de livraisons\\\": null\\n}\\n\\nTexte :\\n{{ $json.text }}\"\n    }\n  ]\n}",
