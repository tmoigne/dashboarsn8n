        "jsCode": "const raw = $input.first().json.output ?? $input.first().json;\nlet result = {};\ntry {\n  const str = typeof raw === 'string' ? raw : JSON.stringify(raw);\n  const match = str.match(/\\{[\\s\\S]*\\}/);\n  result = JSON.parse(match?.[0] ?? '{}');\n} catch(e) {\n  result = { message: String(raw) };\n}\nresult.success = true;\nreturn [{ json: result }];"
