        "jsCode": "const response = $input.first().json;\nconst text = response.content?.[0]?.text ?? '{}';\nlet parsed = {};\ntry {\n  const jsonMatch = text.match(/\\{[\\s\\S]*\\}/);\n  parsed = JSON.parse(jsonMatch?.[0] ?? '{}');\n} catch(e) {\n  parsed = {};\n}\n\n// Supprime les champs null\nObject.keys(parsed).forEach(k => { if (parsed[k] === null || parsed[k] === '') delete parsed[k]; });\n\n// Construit la formule de recherche Airtable\nconst parts = [];\nif (parsed['Email de contact']) parts.push(`{Email de contact}=\"${parsed['Email de contact']}\"`);\nif (parsed['Numéro de portable']) parts.push(`{Numéro de portable}=\"${parsed['Numéro de portable']}\"`);\nif (parsed['Numéro de téléphone']) parts.push(`{Numéro de téléphone}=\"${parsed['Numéro de téléphone']}\"`);\nif (parsed.Nom && parsed.Prénom) parts.push(`AND({Nom}=\"${parsed.Nom}\",{Prénom}=\"${parsed.Prénom}\")`);\n\nparsed._searchFormula = parts.length > 0 ? `OR(${parts.join(',')})` : 'FALSE()';\n\nreturn [{ json: parsed }];"
