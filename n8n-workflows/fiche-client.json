        "jsCode": "const recherche = $('Airtable — Rechercher').all();\nconst existait = recherche.length > 0 && recherche[0].json.id;\nconst upsert = $input.first().json;\nconst client = $('Valide + Formule').first().json;\n\nreturn [{ json: {\n  success: true,\n  action: existait ? 'updated' : 'created',\n  airtable_id: upsert.id,\n  client: {\n    Nom: client.Nom,\n    Prénom: client.Prénom,\n    'Email de contact': client['Email de contact'],\n    Ville: client.Ville\n  }\n} }];"
