        "responseBody": "={{ '[ CSV в†’ JSON вЂ” ' + $json.rows + ' lignes Г— ' + $json.cols + ' colonnes ]\\nColonnes : ' + $json.headers.join(', ') + '\\n\\n' + $json.result }}",
        "options": {}
      },
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [560, 800],
      "id": "d1e2f3a4-0002-0002-0002-000000000002",
      "name": "RГ©pondre CSV"
