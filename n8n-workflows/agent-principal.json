    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "={{ $json.matches.length === 0 ? 'вњ“ Aucune erreur dГ©tectГ©e' : $json.matches.length + ' erreur(s) trouvГ©e(s)\\n\\n' + $json.matches.map(m => 'вЂў \"' + m.context.text.substring(m.context.offset, m.context.offset + m.context.length) + '\"' + (m.replacements.length > 0 ? ' в†’ ' + m.replacements[0].value : '') + '\\n  ' + m.message).join('\\n\\n') }}",
        "options": {}
      },
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [560, 1000],
      "id": "e1f2a3b4-0002-0002-0002-000000000002",
      "name": "RГ©pondre Correcteur"
    },

    {
      "parameters": {
        "jsCode": "const text = $json.body.text.toLowerCase();\n\nconst langs = [\n  { name: 'FranГ§ais', words: ['le','la','les','de','du','et','en','est','que','qui','dans','sur','avec','pour','par','au','une','des','ce','se','son','cette','mais','plus','aussi','comme','bien','trГЁs','tout','ГЄtre'] },\n  { name: 'Anglais', words: ['the','is','are','was','were','have','has','been','will','would','this','that','with','from','they','their','there','which','about','when','what','said','can','could','should','one','all','not','but','had'] },\n  { name: 'Espagnol', words: ['el','la','los','las','de','del','en','es','que','con','por','para','una','este','esta','pero','mГЎs','como','todo','cuando','desde','tiene','entre','tambiГ©n','mismo','sobre','cada','otro','serГ­a'] },\n  { name: 'Allemand', words: ['der','die','das','und','in','von','zu','den','des','mit','ist','fГјr','auf','dem','nicht','als','ein','eine','sich','auch','war','noch','eine','durch','werden','nach','hier','wird','aber','oder'] },\n  { name: 'Italien', words: ['il','la','le','di','della','in','che','per','un','una','nel','con','non','piГ№','anche','come','della','sono','questo','questa','hanno','tutto','loro','parte','suo','sua','stato','puГІ'] }\n];\n\nconst scores = langs.map(lang => ({\n  name: lang.name,\n  score: lang.words.filter(w => new RegExp('\\\\b' + w + '\\\\b').test(text)).length\n})).sort((a, b) => b.score - a.score);\n\nconst total = scores.reduce((s, l) => s + l.score, 0) || 1;\nconst top = scores[0];\n\nreturn [{ json: { detected: top.name, confidence: Math.round((top.score / total) * 100), scores } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [320, 1200],
      "id": "f1a2b3c4-0001-0001-0001-000000000001",
      "name": "Detect Lang"
    },
