    {
      "parameters": {
        "jsCode": "const text = $json.body.text;\n\nconst words = text.trim().split(/\\s+/).filter(w => w.length > 0);\nconst sentences = text.split(/[.!?]+/).filter(s => s.trim().length > 0);\nconst paragraphs = text.split(/\\n\\n+/).filter(p => p.trim().length > 0);\nconst chars = text.length;\nconst charsNoSpace = text.replace(/\\s/g, '').length;\nconst readingTime = Math.max(1, Math.ceil(words.length / 200));\n\nreturn [{ json: { words: words.length, chars, charsNoSpace, sentences: sentences.length, paragraphs: paragraphs.length, readingTime } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [320, 600],
      "id": "c1d2e3f4-0001-0001-0001-000000000001",
      "name": "Statistiques"
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "={{ 'рџ“Љ Statistiques du texte\\n\\nвЂў Mots         : ' + $json.words + '\\nвЂў CaractГЁres   : ' + $json.chars + ' (' + $json.charsNoSpace + ' sans espaces)\\nвЂў Phrases      : ' + $json.sentences + '\\nвЂў Paragraphes  : ' + $json.paragraphs + '\\nвЂў Lecture      : ~' + $json.readingTime + ' min' }}",
        "options": {}
      },
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [560, 600],
      "id": "c1d2e3f4-0002-0002-0002-000000000002",
      "name": "RГ©pondre Stats"
    },

    {
      "parameters": {
        "jsCode": "const text = $json.body.text.trim();\nif (!text) return [{ json: { result: '[]', rows: 0, cols: 0 } }];\n\nconst lines = text.split('\\n').filter(l => l.trim());\nconst sep = lines[0].includes('\\t') ? '\\t' : ',';\nconst headers = lines[0].split(sep).map(h => h.trim().replace(/^\"|\"$/g, ''));\n\nconst rows = lines.slice(1).map(line => {\n  let values;\n  if (sep === ',') {\n    values = line.match(/(?:\"[^\"]*\"|[^,]+)/g)?.map(v => v.trim().replace(/^\"|\"$/g, '')) ?? [];\n  } else {\n    values = line.split('\\t').map(v => v.trim());\n  }\n  return headers.reduce((obj, h, i) => ({ ...obj, [h]: values[i] ?? '' }), {});\n});\n\nreturn [{ json: { result: JSON.stringify(rows, null, 2), rows: rows.length, cols: headers.length, headers } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [320, 800],
      "id": "d1e2f3a4-0001-0001-0001-000000000001",
      "name": "CSV vers JSON"
    },
